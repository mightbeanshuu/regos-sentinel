{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm --prefix web ci",
  "buildCommand": "npm --prefix web run build",
  "outputDirectory": "web/.next",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "excludeFiles": "{services/api/tests/**,services/api/scripts/**,demo/**,docs/**}"
    }
  }
}
